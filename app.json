{
  "expo": {
    "name": "NaijaLearn",
    "slug": "naija-learn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "naijalearnapp",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#065f46"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.naijalearnapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#065f46"
      },
      "package": "com.yourname.naijalearnapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "unstable_useServerMiddleware": true
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}