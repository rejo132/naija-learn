{
  "expo": {
    "name": "Learnova",
    "slug": "learnova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#008751",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#008751"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.learnova.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Learnova uses the microphone for voice input to answer questions.",
        "NSSpeechRecognitionUsageDescription": "Learnova uses speech recognition so you can speak your answers.",
        "NSCameraUsageDescription": "Learnova uses the camera to scan homework."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#008751"
      },
      "package": "com.learnova.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Learnova",
      "shortName": "Learnova",
      "description": "AI-powered learning app for Nigerian primary school students. Primary 1–6, 4 languages, NERDC curriculum.",
      "themeColor": "#008751",
      "backgroundColor": "#F9F6F0"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a7a4a",
          "sounds": []
        }
      ],
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#008751",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "scheme": "learnova",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "description": "Learnova — AI-powered primary school tutoring app for Nigerian children (Primary 1–6). Features personalised AI tutors, gamification, and full Nigerian curriculum alignment.",
    "keywords": [
      "education",
      "nigeria",
      "primary school",
      "AI tutor",
      "kids learning",
      "gamification"
    ],
    "owner": "rejeshos-organization",
    "extra": {
      "eas": {
        "projectId": "53a5a55d-f949-4d25-b2e3-fb94397d6f2a"
      }
    }
  }
}
