# --- Expo app (client) — copy to .env ---

# Get from https://supabase.com → Project Settings → API
# EXPO_PUBLIC_SUPABASE_URL — Project URL (e.g. https://xxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY — anon / publishable key (safe to embed in the app)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — get from https://sentry.io → Project → DSN
EXPO_PUBLIC_SENTRY_DSN=

# --- Supabase Edge Function secrets (never commit supabase/.env) ---
# ANTHROPIC_API_KEY — set in supabase/.env for local `supabase functions serve`
# or via: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
